# Скопируй этот файл в .env и заполни своими значениями.
# .env НИКОГДА не должен попадать в Git/GitHub!

# Токен бота, который дал тебе @BotFather
BOT_TOKEN=сюда_свой_токен

# ID админов через запятую (можно узнать свой ID через бота @userinfobot)
ADMIN_IDS=8925518277,8350819510

# Опциональные лимиты (можно не трогать - возьмутся значения по умолчанию)
MAX_INPUT_DURATION_SEC=1800
MAX_FILE_SIZE_MB=500
TARGET_CLIP_SECONDS=60
